{
  "name": "mr-burns",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.2.19",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "cd apps/web && bun run dev",
    "dev:daemon": "cd apps/daemon && bun run dev",
    "dev:desktop": "cd apps/desktop && BURNS_DESKTOP_WEB_URL=${BURNS_DESKTOP_WEB_URL:-http://localhost:5173} bun run dev",
    "dev:desktop-solo": "bun ./scripts/dev/run-desktop-solo.ts",
    "build:web": "cd apps/web && bun run build",
    "typecheck": "bunx tsc -p packages/shared/tsconfig.json --noEmit && bunx tsc -p packages/client/tsconfig.json --noEmit && cd apps/web && bun run typecheck && cd ../daemon && bun run typecheck"
  }
}
